</x-dc>{% endraw %}
<script type="text/x-dc" data-dc-script data-props="{&quot;$preview&quot;:{&quot;width&quot;:&quot;100%&quot;,&quot;height&quot;:&quot;100%&quot;},&quot;partyColors&quot;:{&quot;editor&quot;:&quot;enum&quot;,&quot;options&quot;:[&quot;Muted&quot;,&quot;Vivid&quot;,&quot;Neutral&quot;],&quot;default&quot;:&quot;Muted&quot;,&quot;tsType&quot;:&quot;string&quot;},&quot;density&quot;:{&quot;editor&quot;:&quot;enum&quot;,&quot;options&quot;:[&quot;Comfortable&quot;,&quot;Compact&quot;],&quot;default&quot;:&quot;Compact&quot;,&quot;tsType&quot;:&quot;string&quot;},&quot;accent&quot;:{&quot;editor&quot;:&quot;enum&quot;,&quot;options&quot;:[&quot;Flag red&quot;,&quot;Sky blue&quot;,&quot;Navy&quot;],&quot;default&quot;:&quot;Sky blue&quot;,&quot;tsType&quot;:&quot;string&quot;}}">
class Component extends DCLogic {
  state = { view:'field', selectedId:'newsom', q:'', party:[], bucket:'', quick:'', sort:'score', dir:'desc', mode:'board', dq:'', wireParty:'', wireType:'', wireQ:'' };

  TODAY = new Date({{ generated_at }});

  WEIGHTS = {
    declared:{w:40,label:'Formal FEC candidacy / launch'},
    exploratory:{w:30,label:'Exploratory committee'},
    consideringQuote:{w:20,label:'Direct "considering" quote'},
    softConsidering:{w:12,label:'Soft / "not ruling out" quote'},
    earlyState:{w:10,label:'Early-state travel (IA/NH/SC/NV)'},
    donors:{w:10,label:'Donor meetings / PAC activity'},
    staffing:{w:10,label:'Campaign staffing / consultants'},
    mediaBlitz:{w:5,label:'National media blitz'},
    endorsedOther:{w:-20,label:'Endorsed another candidate'},
    ruledOut:{w:-40,label:'Explicitly ruled out'},
    barred:{w:-100,label:'Constitutionally ineligible'}
  };
  TIERS = {
    5:{label:'Declared',c:'#9E3B34',desc:'Filed FEC Form 2 / formal launch'},
    4:{label:'Exploratory',c:'#B26A1C',desc:'Exploratory committee / testing the waters'},
    3:{label:'Considering',c:'#A8842C',desc:'Direct "considering" quote on record'},
    2:{label:'Positioning',c:'#3F5C86',desc:'Travel, donors, staff, media activity'},
    1:{label:'Floated',c:'#7C8794',desc:'Floated / "not ruling out"'},
    0:{label:'Inactive',c:'#A7ABA6',desc:'Ruled out, ineligible, or dormant'}
  };
  CONF = {'Very high':4,'High':3,'Medium':2,'Low':1,'Noise':0};
  CONFC = {'Very high':'#2E7D4F','High':'#3A8F55','Medium':'#A8842C','Low':'#B08A2A','Noise':'#B0AEA4'};

  PARTY_PALETTES = {
    Muted:{Democrat:'#3F5C86',Republican:'#9E3B34',Libertarian:'#A8842C',Independent:'#3E7E72'},
    Vivid:{Democrat:'#1F4FB0',Republican:'#CE2029',Libertarian:'#C79A18',Independent:'#2F8F7C'},
    Neutral:{Democrat:'#3A4453',Republican:'#3A4453',Libertarian:'#3A4453',Independent:'#3A4453'}
  };

  SEED = {{ seed_json }};

  // ---------- engine ----------
  daysSince(d){ return Math.floor((this.TODAY - new Date(d))/86400000); }
  recencyTerm(d){ const n=this.daysSince(d); if(n<=30) return {label:'Recency boost (signal '+n+'d ago)',w:5}; if(n>90) return {label:'Stale (no signal '+n+'d)',w:-10}; return null; }
  deriveStatus(keys){
    if(keys.includes('barred')) return {tier:0,label:'Ineligible'};
    if(keys.includes('ruledOut')) return {tier:0,label:'Ruled out'};
    if(keys.includes('declared')) return {tier:5,label:'Declared'};
    if(keys.includes('exploratory')) return {tier:4,label:'Exploratory'};
    if(keys.includes('consideringQuote')) return {tier:3,label:'Considering'};
    const behav = keys.some(k=>['earlyState','donors','staffing','mediaBlitz'].includes(k));
    if(behav) return {tier:2,label:'Positioning'};
    if(keys.includes('softConsidering')) return {tier:1,label:'Floated'};
    return {tier:0,label:'Inactive'};
  }
  breakdown(c){
    const items=[]; const order=['declared','exploratory','consideringQuote','softConsidering'];
    const top=order.find(k=>c.keys.includes(k));
    if(top) items.push({label:this.WEIGHTS[top].label,w:this.WEIGHTS[top].w});
    ['earlyState','donors','staffing','mediaBlitz'].forEach(k=>{ if(c.keys.includes(k)) items.push({label:this.WEIGHTS[k].label,w:this.WEIGHTS[k].w}); });
    const r=this.recencyTerm(c.lastSignal); if(r) items.push(r);
    ['endorsedOther','ruledOut','barred'].forEach(k=>{ if(c.keys.includes(k)) items.push({label:this.WEIGHTS[k].label,w:this.WEIGHTS[k].w}); });
    return items;
  }
  score(c){ return Math.max(0,Math.min(100, this.breakdown(c).reduce((a,b)=>a+b.w,0))); }
  enrich(c){ const st=this.deriveStatus(c.keys); return Object.assign({},c,{tier:st.tier,statusLabel:st.label,score:this.score(c),confRank:this.CONF[c.conf]||0,days:this.daysSince(c.lastSignal)}); }
  all(){ return this.SEED.map(c=>this.enrich(c)); }

  isFresh(x){ return x.days<=7; }
  isMover(x){ return x.delta!==0 || x.days<=14; }

  partyColor(p){ const mode=this.props.partyColors||'Muted'; return (this.PARTY_PALETTES[mode]||this.PARTY_PALETTES.Muted)[p]||'#7A7A7A'; }
  partyLetter(p){ return ({Democrat:'D',Republican:'R',Libertarian:'L',Independent:'I'})[p]||'·'; }
  accentColor(){ return ({'Flag red':'#CE2029','Sky blue':'#3F6FB5','Navy':'#002D62'})[this.props.accent||'Flag red']; }
  compact(){ return (this.props.density||'Comfortable')==='Compact'; }

  fmt(iso,opts){ return new Date(iso+'T12:00:00').toLocaleDateString('en-US',opts); }
  parseSource(h){ const i=h.lastIndexOf(' - '); if(i>0 && h.length-i<46 && h.length-i>4) return {title:h.slice(0,i),source:h.slice(i+3)}; return {title:h,source:'Tracker note'}; }
  recencyLabel(days){ if(days<=0) return 'today'; if(days===1) return '1d ago'; if(days<=45) return days+'d ago'; return Math.round(days/30)+'mo ago'; }

  // ---------- nav helpers ----------
  go(view){ this.setState({view}); if(typeof window!=='undefined'){ try{ window.scrollTo(0,0); }catch(e){} } }
  select(id){ this.setState({view:'dossiers',selectedId:id}); try{ window.scrollTo(0,0); }catch(e){} }
  toggleParty(v){ const p=this.state.party.slice(); const i=p.indexOf(v); if(i>=0)p.splice(i,1); else p.push(v); this.setState({party:p}); }
  setQuick(k){ this.setState({quick:this.state.quick===k?'':k}); }
  sortBy(col){ if(this.state.sort===col) this.setState({dir:this.state.dir==='asc'?'desc':'asc'}); else this.setState({sort:col,dir:(col==='name'||col==='party')?'asc':(col==='days'?'asc':'desc')}); }

  filteredField(){
    let r=this.all();
    const s=this.state;
    if(s.party.length) r=r.filter(x=>s.party.includes(x.party));
    if(s.bucket) r=r.filter(x=>x.bucket===s.bucket);
    if(s.q){ const q=s.q.toLowerCase(); r=r.filter(x=>(x.name+' '+x.role).toLowerCase().includes(q)); }
    if(s.quick==='movers') r=r.filter(x=>this.isMover(x));
    if(s.quick==='declared') r=r.filter(x=>x.tier>=4);
    if(s.quick==='front') r=r.filter(x=>x.pollLead);
    const dir=s.dir==='asc'?1:-1;
    const key=s.sort;
    r.sort((a,b)=>{ let va=a[key],vb=b[key]; if(key==='tierRank'){va=a.tier;vb=b.tier;} if(typeof va==='string') return va.localeCompare(vb)*dir; if(va===vb) return b.score-a.score; return (va-vb)*dir; });
    return r;
  }

  // ---------- render ----------
  renderVals(){
    const s=this.state; const acc=this.accentColor(); const all=this.all(); const compact=this.compact();
    const tdPad = compact ? '7px 12px' : '11px 14px';

    const navTabs=[['field','The Field'],['dossiers','Dossiers'],['wire','The Wire']].map(([k,label])=>{
      const on=s.view===k;
      return { label, go:()=>this.go(k),
        labelStyle:{color:on?'#13294B':'#8A8470',transition:'color .12s'},
        underline:{position:'absolute',left:4,right:4,bottom:0,height:'3px',background:on?acc:'transparent',borderRadius:'2px 2px 0 0'} };
    });

    // stats
    const cnt=t=>all.filter(x=>x.tier===t).length;
    const stats=[
      {n:all.filter(x=>x.bucket==='formal').length,label:'Formal',c:'#9E3B34'},
      {n:cnt(3),label:'Considering',c:'#A8842C'},
      {n:cnt(2),label:'Positioning',c:'#3F5C86'},
      {n:cnt(1),label:'Floated',c:'#7C8794'},
      {n:all.filter(x=>x.bucket==='out').length,label:'Ruled out',c:'#A7ABA6'},
      {n:all.length,label:'Tracked',c:'#13294B'}
    ].map(x=>({n:x.n,label:x.label,barStyle:{background:x.c}}));

    // party chips
    const partyChips=['Democrat','Republican','Libertarian','Independent'].map(p=>{
      const on=s.party.includes(p); const col=this.partyColor(p);
      return { name:p, label:p.slice(0,3), toggle:()=>this.toggleParty(p),
        style:{appearance:'none',cursor:'pointer',font:'inherit',fontSize:'12px',fontWeight:600,padding:'7px 11px',borderRadius:'3px',border:'1px solid '+(on?col:'#D5CBB3'),background:on?col:'#FCFAF4',color:on?'#fff':'#6A6450'} };
    });

    const quickDefs=[['movers','Movers',x=>this.isMover(x)],['declared','In the ring',x=>x.tier>=4],['front','Poll leaders',x=>x.pollLead]];
    const quickChips=quickDefs.map(([k,label,f])=>{ const on=s.quick===k;
      return { label, n:all.filter(f).length, toggle:()=>this.setQuick(k),
        style:{appearance:'none',cursor:'pointer',font:'inherit',fontSize:'12px',fontWeight:600,padding:'6px 12px',borderRadius:'999px',border:'1px solid '+(on?'#13294B':'#D5CBB3'),background:on?'#13294B':'#FCFAF4',color:on?'#F4EFE2':'#6A6450'} };
    });

    const colDefs=[['rank','#'],['name','Candidate'],['party','Lane'],['tierRank','Status'],['score','Momentum'],['days','Last signal'],['confRank','Confidence']];
    const cols=colDefs.map(([key,label])=>{ const sorted=s.sort===key||(key==='rank'&&false); const isSorted=s.sort===key;
      return { label, sort:()=> key==='rank'?null:this.sortBy(key),
        arrow:isSorted?(s.dir==='asc'?' ▴':' ▾'):'',
        style:{textAlign:'left',padding:'10px 14px',fontSize:'10.5px',textTransform:'uppercase',letterSpacing:'.05em',color:isSorted?'#13294B':'#8A8470',fontWeight:700,cursor:key==='rank'?'default':'pointer',whiteSpace:'nowrap',background:'#F3ECDA',borderBottom:'1px solid #E0D7C1',userSelect:'none'} };
    });

    const sheetColDefs=[['rank','#'],['name','Candidate'],['party','Lane'],['tierRank','Status'],['bucket','Posture'],['score','Mom'],['days','Signal'],['confRank','Conf']];
    const sheetCols=sheetColDefs.map(([key,label])=>{ const isSorted=s.sort===key;
      return { label, sort:()=> key==='rank'?null:this.sortBy(key), arrow:isSorted?(s.dir==='asc'?' ▴':' ▾'):'',
        style:{textAlign:'left',padding:'6px 9px',fontSize:'10px',textTransform:'uppercase',letterSpacing:'.04em',color:isSorted?'#13294B':'#8A8470',fontWeight:700,cursor:key==='rank'?'default':'pointer',whiteSpace:'nowrap',background:'#EFE7D4',borderBottom:'1px solid #D8CFB8',borderRight:'1px solid #E4DBC6',position:'sticky',top:'0',zIndex:'1'} };
    });

    const fr=this.filteredField();
    const rows=fr.map((x,i)=>{
      const col=this.partyColor(x.party); const tier=this.TIERS[x.tier];
      return {
        id:x.id, rank:i+1, name:x.name, role:x.role, party:x.party, letter:this.partyLetter(x.party),
        avatar:x.img, score:x.score, statusLabel:x.statusLabel, conf:x.conf, headline:x.headline,
        recency:this.recencyLabel(x.days),
        bucketLabel:({formal:'Formal',considering:'Considering',soft:'Soft',edge:'Edge',out:'Ruled out'})[x.bucket],
        tierText:{color:tier.c,fontWeight:600,whiteSpace:'nowrap'},
        momStyle:{fontFamily:"'Space Mono',monospace",fontWeight:700,color:tier.c,fontVariantNumeric:'tabular-nums'},
        laneSm:{display:'inline-flex',alignItems:'center',justifyContent:'center',width:'17px',height:'17px',borderRadius:'3px',background:col,color:'#fff',fontSize:'10px',fontWeight:700,flex:'none'},
        open:()=>this.select(x.id),
        td:{padding:tdPad,verticalAlign:'middle',fontSize:'13px',color:'#13294B'},
        tdRank:{padding:tdPad,verticalAlign:'middle',color:'#A39A82',fontFamily:"'Space Mono',monospace",fontSize:'12px',width:'30px'},
        barStyle:{background:col},
        laneStyle:{display:'inline-flex',alignItems:'center',justifyContent:'center',width:'19px',height:'19px',borderRadius:'3px',background:col,color:'#fff',fontSize:'11px',fontWeight:700,flex:'none'},
        tierBadge:{display:'inline-block',fontSize:'11px',fontWeight:600,padding:'2px 9px',borderRadius:'3px',color:'#fff',whiteSpace:'nowrap',background:tier.c},
        trackStyle:{width:x.score+'%',background:tier.c},
        scoreColor:{color:tier.c},
        confDot:{background:this.CONFC[x.conf]},
        freshDot:this.isFresh(x)?{display:'inline-block',width:'6px',height:'6px',borderRadius:'50%',background:acc,boxShadow:'0 0 5px '+acc}:{display:'none'},
        starStyle:x.pollLead?{color:'#9E3B34',fontSize:'12px',marginLeft:'7px'}:{display:'none'}
      };
    });

    const feed=all.filter(x=>x.bucket!=='out').sort((a,b)=>new Date(b.lastSignal)-new Date(a.lastSignal)).slice(0,7).map(x=>({
      name:x.name, party:x.party, headline:this.parseSource(x.headline).title, date:this.fmt(x.lastSignal,{month:'short',day:'numeric'}),
      open:()=>this.select(x.id),
      dotStyle:{display:'inline-block',width:'6px',height:'6px',borderRadius:'50%',flex:'none',background:this.isFresh(x)?acc:'#C7BDA3'}
    }));

    const tiers=[5,4,3,2,1,0].map(t=>({ rank:t, label:this.TIERS[t].label, desc:this.TIERS[t].desc,
      badge:{display:'inline-flex',alignItems:'center',justifyContent:'center',width:'20px',height:'20px',borderRadius:'3px',background:this.TIERS[t].c,color:'#fff',fontSize:'11px',fontWeight:700,flex:'none',fontFamily:"'Space Mono',monospace"} }));

    const tabStyle=on=>({appearance:'none',border:'0',cursor:'pointer',font:'inherit',fontSize:'12.5px',fontWeight:600,padding:'8px 13px',background:on?'#13294B':'#FCFAF4',color:on?'#F4EFE2':'#8A8470'});

    const base={
      asOf:'June 14, 2026', trackedCount:all.length,
      isField:s.view==='field', isDossiers:s.view==='dossiers', isWire:s.view==='wire',
      navTabs, goHome:()=>this.go('field'), goWire:()=>this.go('wire'),
      // field
      stats, q:s.q, bucket:s.bucket,
      onSearch:(e)=>this.setState({q:e.target.value}),
      onBucket:(e)=>this.setState({bucket:e.target.value}),
      partyChips, quickChips,
      anyFilter:!!(s.q||s.party.length||s.bucket||s.quick),
      clearFilters:()=>this.setState({q:'',party:[],bucket:'',quick:''}),
      isBoard:s.mode==='board', isSheet:s.mode==='sheet', isCards:s.mode==='cards', notSheet:s.mode!=='sheet',
      setBoard:()=>this.setState({mode:'board'}), setSheet:()=>this.setState({mode:'sheet'}), setCards:()=>this.setState({mode:'cards'}),
      boardTabStyle:tabStyle(s.mode==='board'), sheetTabStyle:tabStyle(s.mode==='sheet'), cardsTabStyle:tabStyle(s.mode==='cards'),
      cols, sheetCols, rows, feed, tiers,
      counterText:all.filter(x=>x.days<=14).length+' moved in 14 days',
      shownText:fr.length+' shown', noResults:fr.length===0
    };
    return Object.assign(base, this.dossierVals(), this.wireVals());
  }

  dossierVals(){
    const s=this.state; const acc=this.accentColor();
    const c0=this.SEED.find(x=>x.id===s.selectedId)||this.SEED[0];
    const x=this.enrich(c0); const tier=this.TIERS[x.tier]; const col=this.partyColor(x.party);
    const bd=this.breakdown(c0).map(b=>({label:b.label,val:(b.w>=0?'+':'')+b.w,valStyle:{color:b.w>=0?'#2E7D4F':'#9E3B34',fontFamily:"'Space Mono',monospace",fontWeight:700,fontVariantNumeric:'tabular-nums'}}));
    const buckets={formal:'Formal — declared / exploratory',considering:'Actively considering',soft:'Soft / positioning',edge:'Edge / conditional',out:'Ruled out / inactive'};
    const facts=[['Lane',x.party],['Office / role',x.role],['Posture',buckets[x.bucket]],['Last signal',this.fmt(x.lastSignal,{month:'long',day:'numeric',year:'numeric'})+' · '+this.recencyLabel(x.days)],['Confidence',x.conf],['Poll standing',x.pollLead||'—']].map(([k,v])=>({k,v}));
    const ps=this.parseSource(x.headline);
    const tags=(x.tags||[]).map(t=>({t}));

    const dir=this.all().sort((a,b)=>b.score-a.score).filter(r=>{ if(!s.dq) return true; const q=s.dq.toLowerCase(); return (r.name+' '+r.role).toLowerCase().includes(q); }).map(r=>{
      const on=r.id===s.selectedId; const rc=this.partyColor(r.party);
      return { id:r.id, name:r.name, role:r.role, avatar:r.img, score:r.score,
        open:()=>this.setState({selectedId:r.id}),
        rowStyle:{display:'flex',alignItems:'center',gap:'10px',padding:'9px 12px',cursor:'pointer',borderLeft:'3px solid '+(on?rc:'transparent'),background:on?'#F1E9D5':'transparent',borderBottom:'1px solid #ECE4D2'},
        nameStyle:{fontWeight:on?700:600,color:'#13294B',fontSize:'13px',whiteSpace:'nowrap',overflow:'hidden',textOverflow:'ellipsis'},
        tierDot:{display:'inline-block',width:'8px',height:'8px',borderRadius:'50%',flex:'none',background:this.TIERS[r.tier].c},
        scoreStyle:{marginLeft:'auto',fontFamily:"'Space Mono',monospace",fontWeight:700,fontSize:'13px',color:this.TIERS[r.tier].c} };
    });

    const dossier={
      name:x.name, role:x.role, party:x.party, letter:this.partyLetter(x.party),
      portraitBg:{width:'104px',height:'128px',borderRadius:'4px',backgroundColor:'#1a3358',backgroundImage:'url("'+x.img+'")',backgroundSize:'cover',backgroundPosition:'center top',flex:'none',border:'1px solid #2C476B',boxShadow:'0 6px 20px -8px rgba(0,0,0,.6)'},
      statusLabel:x.statusLabel, score:x.score, conf:x.conf, why:x.why,
      quote:x.quote, hasQuote:!!x.quote, headlineTitle:ps.title, source:ps.source,
      lastSignalLong:this.fmt(x.lastSignal,{month:'long',day:'numeric',year:'numeric'}), recency:this.recencyLabel(x.days),
      pollLead:x.pollLead||'', hasPoll:!!x.pollLead, breakdown:bd, facts, tags, hasTags:tags.length>0,
      tierBadge:{display:'inline-block',fontSize:'12px',fontWeight:600,padding:'3px 11px',borderRadius:'3px',color:'#fff',background:tier.c},
      laneChip:{display:'inline-flex',alignItems:'center',justifyContent:'center',width:'22px',height:'22px',borderRadius:'4px',background:col,color:'#fff',fontSize:'12px',fontWeight:700,flex:'none'},
      laneColor:{color:col,fontWeight:600},
      trackStyle:{width:x.score+'%',background:tier.c},
      scoreColor:{color:tier.c},
      starShow:x.pollLead?{color:'#9E3B34'}:{display:'none'},
      confDot:{display:'inline-block',width:'8px',height:'8px',borderRadius:'50%',background:this.CONFC[x.conf],flex:'none'},
      openWire:()=>this.setState({view:'wire',wireQ:x.name,wireParty:'',wireType:''})
    };
    return { dossier, dirList:dir, dossierCount:dir.length, dq:s.dq, onDq:(e)=>this.setState({dq:e.target.value}) };
  }
  wireVals(){
    const s=this.state; const acc=this.accentColor();
    const typeLabels={declared:'Declared',exploratory:'Exploratory',consideringQuote:'“Considering” quote',softConsidering:'Not ruling out',earlyState:'Early-state travel',donors:'Donor activity',staffing:'Staffing',mediaBlitz:'Media blitz',endorsedOther:'Endorsed another',ruledOut:'Ruled out'};
    let items=this.all().map(x=>{ const ps=this.parseSource(x.headline);
      const tagKeys=(x.keys||[]).filter(k=>typeLabels[k]).slice(0,2).map(k=>({label:typeLabels[k]}));
      return { candId:x.id, name:x.name, party:x.party, letter:this.partyLetter(x.party), role:x.role, partyColor:this.partyColor(x.party),
        title:ps.title, source:ps.source, dateRaw:x.lastSignal, date:this.fmt(x.lastSignal,{month:'short',day:'numeric'}),
        keys:x.keys, tier:x.tier, tierLabel:this.TIERS[x.tier].label, tierColor:this.TIERS[x.tier].c, score:x.score, fresh:this.isFresh(x), mover:this.isMover(x), days:x.days, tagKeys, avatar:x.img };
    });
    items.sort((a,b)=>new Date(b.dateRaw)-new Date(a.dateRaw));
    let f=items.slice();
    if(s.wireParty) f=f.filter(i=>i.party===s.wireParty);
    if(s.wireType) f=f.filter(i=>i.keys.includes(s.wireType));
    if(s.wireQ){ const q=s.wireQ.toLowerCase(); f=f.filter(i=>(i.name+' '+i.title+' '+i.role).toLowerCase().includes(q)); }

    const mk=(i)=>({ name:i.name, letter:i.letter, role:i.role, title:i.title, source:i.source, date:i.date, recency:this.recencyLabel(i.days),
      avatarBg:{width:'78px',height:'94px',borderRadius:'4px',backgroundColor:'#E7E0CF',backgroundImage:'url("'+i.avatar+'")',backgroundSize:'cover',backgroundPosition:'center top',flex:'none',border:'1px solid #DDD3BB'},
      tagKeys:i.tagKeys, tierLabel:i.tierLabel,
      open:()=>this.select(i.candId),
      laneChip:{display:'inline-flex',alignItems:'center',justifyContent:'center',width:'18px',height:'18px',borderRadius:'3px',background:i.partyColor,color:'#fff',fontSize:'10.5px',fontWeight:700,flex:'none'},
      dateStyle:{fontFamily:"'Space Mono',monospace",fontSize:'11px',fontWeight:700,color:i.fresh?acc:'#9A917A',whiteSpace:'nowrap'},
      moverFlag:i.fresh?{display:'inline',color:acc,fontWeight:700,marginRight:'5px'}:{display:'none'},
      tierStyle:{display:'inline-block',fontSize:'9.5px',fontWeight:700,textTransform:'uppercase',letterSpacing:'.04em',padding:'1px 6px',borderRadius:'3px',color:'#fff',background:i.tierColor} });

    const lead=f.length?mk(f[0]):null;
    const river=f.slice(1).map(mk);

    const typeOpts=[{value:'',label:'All signal types'}].concat(Object.keys(typeLabels).map(k=>({value:k,label:typeLabels[k]})));

    return {
      wireHasLead:!!lead, wireLead:lead||{}, wireItems:river, wireCount:f.length, wireNoResults:f.length===0,
      wireQ:s.wireQ, onWireQ:(e)=>this.setState({wireQ:e.target.value}),
      wireParty:s.wireParty, onWireParty:(e)=>this.setState({wireParty:e.target.value}),
      wireType:s.wireType, onWireType:(e)=>this.setState({wireType:e.target.value}), wireTypeOpts:typeOpts,
      wireAnyFilter:!!(s.wireQ||s.wireParty||s.wireType),
      clearWire:()=>this.setState({wireQ:'',wireParty:'',wireType:''})
    };
  }
}
</script>
</body>
</html>
