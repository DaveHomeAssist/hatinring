<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>2028 Hat-in-Ring Radar</title>
<meta name="description" content="{{ page_desc }}">
<link rel="canonical" href="{{ canonical_url }}">
<meta name="robots" content="index,follow">
<meta property="og:type" content="website">
<meta property="og:title" content="2028 Hat-in-Ring Radar">
<meta property="og:description" content="{{ page_desc }}">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:image" content="{{ og_image }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="2028 Hat-in-Ring Radar">
<meta name="twitter:description" content="{{ page_desc }}">
<meta name="twitter:image" content="{{ og_image }}">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="alternate" type="application/rss+xml" title="Hat-in-Ring Radar — daily movement" href="/feed.xml">
<script type="application/ld+json">{"@context":"https://schema.org","@type":"WebSite","name":"2028 Hat-in-Ring Radar","url":"{{ canonical_url }}","description":"{{ page_desc }}","publisher":{"@type":"Organization","name":"System by Dave","url":"https://systembydave.com/"}}</script>
<script src="/support.js"></script>
</head>
<body>
<noscript>
<div style="max-width:1100px;margin:0 auto;padding:28px 22px;font-family:system-ui,Arial,sans-serif;color:#13294B">
<h1>2028 Hat-in-Ring Radar</h1>
<p>{{ page_desc }}</p>
<p>Tracking {{ crawl_count }} potential 2028 U.S. presidential candidates on two axes — status tier (the furthest verifiable step taken) and momentum (weighted activity + recency, 0–100) — rebuilt daily from FEC filings and news. The interactive board requires JavaScript; every candidate also has a full static file linked below and in the <a href="/sitemap.xml">sitemap</a>.</p>
<table border="1" cellpadding="6" cellspacing="0"><thead><tr><th>#</th><th>Candidate</th><th>Party</th><th>Status</th><th>Momentum</th></tr></thead>
<tbody>{{ crawl_rows }}</tbody></table>
<p style="opacity:.7;font-size:12px">Auto-built {{ generated_at_human }} UTC · data as of {{ as_of }}.</p>
</div>
</noscript>
{% raw %}<x-dc>
<helmet>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;1,6..72,400;1,6..72,500&family=Space+Grotesk:wght@400;500;600;700&family=Pinyon+Script&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  *{box-sizing:border-box}
  html,body{margin:0;padding:0}
  body{background:#E7E1D2;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
  ::selection{background:#13294B;color:#F4EFE2}
  @keyframes hir-sweep{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
  @keyframes hir-pulse{0%,100%{opacity:.55}50%{opacity:1}}
  @keyframes hir-fade{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}
  .hir-scroll::-webkit-scrollbar{width:9px;height:9px}
  .hir-scroll::-webkit-scrollbar-thumb{background:#CFC6B0;border-radius:6px;border:2px solid #F6F2E8}
  .hir-scroll::-webkit-scrollbar-track{background:transparent}
  input::placeholder{color:#9aa0a8}
</style>
</helmet>
<div style="min-height:100vh;background:#E7E1D2;color:#13294B;font-family:'Space Grotesk',sans-serif;font-size:14px;line-height:1.5">

  <header style="position:sticky;top:0;z-index:30;background:#F4EFE2;border-bottom:2px solid #13294B;box-shadow:0 1px 0 #C9BE9E,0 6px 18px -14px rgba(19,41,75,.5)">
    <div style="max-width:1280px;margin:0 auto;padding:0 22px;display:flex;align-items:center;gap:22px;height:72px">
      <div onClick="{{ goHome }}" style="display:flex;align-items:center;gap:13px;cursor:pointer;flex:none">
        <span style="position:relative;width:42px;height:42px;flex:none;display:block">
          <svg viewBox="0 0 100 100" width="42" height="42" style="display:block;position:absolute;inset:0">
            <circle cx="50" cy="50" r="46" fill="#0E2342" stroke="#13294B" stroke-width="1"></circle>
            <circle cx="50" cy="50" r="33" fill="none" stroke="#3D5675" stroke-width="1"></circle>
            <circle cx="50" cy="50" r="20" fill="none" stroke="#3D5675" stroke-width="1"></circle>
            <circle cx="50" cy="50" r="7" fill="none" stroke="#3D5675" stroke-width="1"></circle>
            <line x1="50" y1="50" x2="50" y2="6" stroke="#2C476B" stroke-width="1"></line>
            <line x1="6" y1="50" x2="94" y2="50" stroke="#2C476B" stroke-width="1"></line>
            <line x1="50" y1="6" x2="50" y2="94" stroke="#2C476B" stroke-width="1"></line>
          </svg>
          <span style="position:absolute;inset:0;border-radius:50%;overflow:hidden">
            <span style="position:absolute;left:50%;top:50%;width:50%;height:50%;transform-origin:top left;background:conic-gradient(from 0deg, rgba(206,32,41,.55), rgba(206,32,41,0) 70deg);animation:hir-sweep 4s linear infinite"></span>
          </span>
          <span style="position:absolute;left:24px;top:13px;width:5px;height:5px;border-radius:50%;background:#CE2029;box-shadow:0 0 6px #CE2029;animation:hir-pulse 2s ease-in-out infinite"></span>
        </span>
        <span style="display:flex;flex-direction:column;line-height:1">
          <span style="font-family:'Pinyon Script',cursive;font-size:27px;color:#13294B;line-height:.8;margin-bottom:2px;white-space:nowrap">Hat-in-Ring</span>
          <span style="font-family:'Space Grotesk',sans-serif;font-size:10px;font-weight:600;letter-spacing:.42em;color:#9E3B34">RADAR</span>
        </span>
      </div>

      <nav style="display:flex;align-items:stretch;gap:2px;height:100%;margin-left:8px">
        <sc-for list="{{ navTabs }}" as="tab" hint-placeholder-count="3">
          <button onClick="{{ tab.go }}" style="appearance:none;border:0;background:none;cursor:pointer;font-family:'Space Grotesk',sans-serif;font-size:13px;font-weight:600;letter-spacing:.02em;padding:0 4px;height:100%;display:flex;align-items:center;position:relative" style-hover="opacity:1">
            <span style="{{ tab.labelStyle }}">{{ tab.label }}</span>
            <span style="{{ tab.underline }}"></span>
          </button>
        </sc-for>
      </nav>

      <div style="margin-left:auto;display:flex;align-items:center;gap:18px;flex:none">
        <div style="text-align:right;line-height:1.25">
          <div style="font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:#8A8470;font-weight:600">As of</div>
          <div style="font-family:'Newsreader',serif;font-size:15px;color:#13294B;font-weight:600">{{ asOf }}</div>
        </div>
        <div style="width:1px;height:34px;background:#D2C8AE"></div>
        <div style="text-align:right;line-height:1.25">
          <div style="font-family:'Space Mono',monospace;font-size:17px;font-weight:700;color:#9E3B34">{{ trackedCount }}</div>
          <div style="font-size:9.5px;letter-spacing:.13em;text-transform:uppercase;color:#8A8470;font-weight:600">names tracked</div>
        </div>
      </div>
    </div>
  </header>

  <!-- ============ THE FIELD ============ -->
  <sc-if value="{{ isField }}" hint-placeholder-val="{{ true }}">
  <main style="max-width:1280px;margin:0 auto;padding:26px 22px 70px">

    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:16px;margin-bottom:18px;flex-wrap:wrap">
      <div>
        <h1 style="font-family:'Newsreader',serif;font-weight:600;font-size:30px;letter-spacing:-.01em;margin:0;color:#13294B">The Field</h1>
        <p style="margin:4px 0 0;color:#6A6450;font-size:13.5px;max-width:540px">A non-partisan reading of who is moving toward a 2028 run — ranked by verifiable steps taken and recent activity, not by who you'd vote for.</p>
      </div>
      <div style="font-size:12px;color:#8A8470;font-family:'Space Mono',monospace;text-align:right">{{ counterText }}</div>
    </div>

    <!-- stats -->
    <div style="display:grid;grid-template-columns:repeat(6,1fr);gap:10px;margin-bottom:20px">
      <sc-for list="{{ stats }}" as="s" hint-placeholder-count="6">
        <div style="background:#FBF8F0;border:1px solid #DED5BD;border-radius:3px;padding:12px 13px;position:relative;overflow:hidden">
          <div style="position:absolute;left:0;top:0;bottom:0;width:3px;{{ s.barStyle }}"></div>
          <div style="font-family:'Newsreader',serif;font-size:27px;font-weight:600;line-height:1;color:#13294B">{{ s.n }}</div>
          <div style="font-size:10px;text-transform:uppercase;letter-spacing:.07em;color:#7A7460;margin-top:6px;font-weight:600">{{ s.label }}</div>
        </div>
      </sc-for>
    </div>

    <!-- toolbar -->
    <div style="display:flex;flex-wrap:wrap;gap:9px;align-items:center;margin-bottom:6px">
      <div style="position:relative;flex:1 1 220px;min-width:180px">
        <span style="position:absolute;left:11px;top:50%;transform:translateY(-50%);color:#A39A82;font-size:13px">⌕</span>
        <input value="{{ q }}" onInput="{{ onSearch }}" placeholder="Search name or office…" style="width:100%;font:inherit;font-size:13px;padding:9px 11px 9px 28px;border:1px solid #D5CBB3;border-radius:3px;background:#FCFAF4;color:#13294B;outline:none">
      </div>
      <div style="display:flex;gap:5px">
        <sc-for list="{{ partyChips }}" as="c" hint-placeholder-count="4">
          <button onClick="{{ c.toggle }}" title="{{ c.name }}" style="{{ c.style }}">{{ c.label }}</button>
        </sc-for>
      </div>
      <select value="{{ bucket }}" onChange="{{ onBucket }}" style="font:inherit;font-size:12.5px;padding:8px 9px;border:1px solid #D5CBB3;border-radius:3px;background:#FCFAF4;color:#13294B;outline:none">
        <option value="">All postures</option>
        <option value="formal">Formal — declared / exploratory</option>
        <option value="considering">Actively considering</option>
        <option value="soft">Soft / positioning</option>
        <option value="edge">Edge / conditional</option>
        <option value="out">Ruled out / ineligible</option>
      </select>
      <div style="display:flex;border:1px solid #D5CBB3;border-radius:3px;overflow:hidden;margin-left:auto">
        <button onClick="{{ setBoard }}" style="{{ boardTabStyle }}">Leaderboard</button>
        <button onClick="{{ setSheet }}" style="{{ sheetTabStyle }}">Sheet</button>
        <button onClick="{{ setCards }}" style="{{ cardsTabStyle }}">Cards</button>
      </div>
    </div>

    <!-- quick filters -->
    <div style="display:flex;gap:7px;flex-wrap:wrap;margin:10px 0 16px">
      <sc-for list="{{ quickChips }}" as="c" hint-placeholder-count="3">
        <button onClick="{{ c.toggle }}" style="{{ c.style }}">{{ c.label }}<span style="opacity:.6;margin-left:6px;font-variant-numeric:tabular-nums">{{ c.n }}</span></button>
      </sc-for>
      <sc-if value="{{ anyFilter }}" hint-placeholder-val="{{ false }}">
        <button onClick="{{ clearFilters }}" style="appearance:none;border:0;background:none;cursor:pointer;color:#9E3B34;font:inherit;font-size:12px;text-decoration:underline;text-underline-offset:3px;margin-left:2px">Clear filters</button>
      </sc-if>
    </div>

    <!-- SHEET (ultra-compact) -->
    <sc-if value="{{ isSheet }}" hint-placeholder-val="{{ false }}">
    <div style="background:#FBF8F0;border:1px solid #DED5BD;border-radius:4px;overflow:hidden;margin-bottom:18px">
      <div style="display:flex;align-items:baseline;justify-content:space-between;padding:10px 14px;border-bottom:1px solid #E4DBC6">
        <h2 style="font-family:'Newsreader',serif;font-weight:600;font-size:15px;margin:0">Field sheet</h2>
        <span style="font-size:11px;color:#8A8470;font-family:'Space Mono',monospace">{{ shownText }} · click a row for the dossier</span>
      </div>
      <div class="hir-scroll" style="overflow:auto;max-height:76vh">
        <table style="width:100%;border-collapse:collapse;min-width:720px;font-variant-numeric:tabular-nums">
          <thead><tr>
            <sc-for list="{{ sheetCols }}" as="col" hint-placeholder-count="8">
              <th onClick="{{ col.sort }}" style="{{ col.style }}">{{ col.label }}{{ col.arrow }}</th>
            </sc-for>
          </tr></thead>
          <tbody>
            <sc-for list="{{ rows }}" as="r" hint-placeholder-count="16">
              <tr onClick="{{ r.open }}" style="cursor:pointer" style-hover="background:#F2E9D4">
                <td style="padding:4px 9px;border-bottom:1px solid #EEE6D2;border-right:1px solid #F0E8D5;font-family:'Space Mono',monospace;font-size:11px;color:#A39A82;text-align:right">{{ r.rank }}</td>
                <td style="padding:4px 9px;border-bottom:1px solid #EEE6D2;border-right:1px solid #F0E8D5;font-size:12.5px;font-weight:600;color:#13294B;white-space:nowrap">{{ r.name }}<span style="{{ r.freshDot }}"></span><span style="{{ r.starStyle }}">★</span></td>
                <td style="padding:4px 9px;border-bottom:1px solid #EEE6D2;border-right:1px solid #F0E8D5;white-space:nowrap"><span style="{{ r.laneSm }}">{{ r.letter }}</span></td>
                <td style="padding:4px 9px;border-bottom:1px solid #EEE6D2;border-right:1px solid #F0E8D5;font-size:12px"><span style="{{ r.tierText }}">{{ r.statusLabel }}</span></td>
                <td style="padding:4px 9px;border-bottom:1px solid #EEE6D2;border-right:1px solid #F0E8D5;font-size:12px;color:#6A6450;white-space:nowrap">{{ r.bucketLabel }}</td>
                <td style="padding:4px 9px;border-bottom:1px solid #EEE6D2;border-right:1px solid #F0E8D5;white-space:nowrap"><span style="display:flex;align-items:center;gap:7px"><span style="{{ r.momStyle }}">{{ r.score }}</span><span style="display:block;width:40px;height:5px;background:#E7DEC9;border-radius:3px;overflow:hidden;flex:none"><span style="display:block;height:100%;{{ r.trackStyle }}"></span></span></span></td>
                <td style="padding:4px 9px;border-bottom:1px solid #EEE6D2;border-right:1px solid #F0E8D5;font-family:'Space Mono',monospace;font-size:11px;color:#6A6450;white-space:nowrap">{{ r.recency }}</td>
                <td style="padding:4px 9px;border-bottom:1px solid #EEE6D2;font-size:11.5px;color:#6A6450;white-space:nowrap"><span style="display:inline-flex;align-items:center;gap:5px"><span style="width:6px;height:6px;border-radius:50%;flex:none;{{ r.confDot }}"></span>{{ r.conf }}</span></td>
              </tr>
            </sc-for>
          </tbody>
        </table>
      </div>
    </div>
    </sc-if>

    <sc-if value="{{ notSheet }}" hint-placeholder-val="{{ true }}">
    <div style="display:grid;grid-template-columns:1fr 312px;gap:20px;align-items:start">
      <div style="min-width:0">
        <!-- LEADERBOARD -->
        <sc-if value="{{ isBoard }}" hint-placeholder-val="{{ true }}">
        <div style="background:#FBF8F0;border:1px solid #DED5BD;border-radius:4px;overflow:hidden">
          <div style="display:flex;align-items:baseline;justify-content:space-between;padding:13px 16px;border-bottom:1px solid #E4DBC6">
            <h2 style="font-family:'Newsreader',serif;font-weight:600;font-size:16px;margin:0">Seriousness leaderboard</h2>
            <span style="font-size:11.5px;color:#8A8470;font-family:'Space Mono',monospace">{{ shownText }}</span>
          </div>
          <div style="overflow-x:auto" class="hir-scroll">
          <table style="width:100%;border-collapse:collapse;min-width:660px">
            <thead><tr>
              <sc-for list="{{ cols }}" as="col" hint-placeholder-count="7">
                <th onClick="{{ col.sort }}" style="{{ col.style }}">{{ col.label }}{{ col.arrow }}</th>
              </sc-for>
            </tr></thead>
            <tbody>
              <sc-for list="{{ rows }}" as="r" hint-placeholder-count="10">
                <tr onClick="{{ r.open }}" style="cursor:pointer;border-bottom:1px solid #ECE4D2" style-hover="background:#F5EFDF">
                  <td style="{{ r.tdRank }}">{{ r.rank }}</td>
                  <td style="{{ r.td }}">
                    <span style="display:flex;align-items:center;gap:10px">
                      <span style="width:3px;height:30px;border-radius:2px;flex:none;{{ r.barStyle }}"></span>
                      <img src="{{ r.avatar }}" alt="" loading="lazy" style="width:30px;height:30px;border-radius:3px;object-fit:cover;object-position:center top;flex:none;background:#E7E0CF;border:1px solid #DDD3BB">
                      <span style="min-width:0">
                        <span style="display:flex;align-items:center;gap:6px"><span style="font-weight:600;color:#13294B;white-space:nowrap">{{ r.name }}</span><span style="{{ r.freshDot }}"></span><span style="{{ r.starStyle }}">★</span></span>
                        <span style="display:block;color:#857E69;font-size:11.5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{ r.role }}</span>
                      </span>
                    </span>
                  </td>
                  <td style="{{ r.td }}"><span style="{{ r.laneStyle }}">{{ r.letter }}</span><span style="color:#6A6450;font-size:12.5px;margin-left:7px">{{ r.party }}</span></td>
                  <td style="{{ r.td }}"><span style="{{ r.tierBadge }}">{{ r.statusLabel }}</span></td>
                  <td style="{{ r.td }}">
                    <span style="display:flex;align-items:center;gap:9px">
                      <span style="font-family:'Space Mono',monospace;font-weight:700;color:#13294B;width:24px">{{ r.score }}</span>
                      <span style="display:block;width:66px;height:6px;background:#E7DEC9;border-radius:3px;overflow:hidden;flex:none"><span style="display:block;height:100%;{{ r.trackStyle }}"></span></span>
                    </span>
                  </td>
                  <td style="{{ r.td }}"><span style="font-size:12.5px;color:#6A6450;font-family:'Space Mono',monospace">{{ r.recency }}</span></td>
                  <td style="{{ r.td }}"><span style="display:inline-flex;align-items:center;gap:5px;font-size:12px;color:#6A6450"><span style="width:7px;height:7px;border-radius:50%;flex:none;{{ r.confDot }}"></span>{{ r.conf }}</span></td>
                </tr>
              </sc-for>
            </tbody>
          </table>
          </div>
        </div>
        </sc-if>

        <!-- CARDS -->
        <sc-if value="{{ isCards }}" hint-placeholder-val="{{ false }}">
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(232px,1fr));gap:12px">
          <sc-for list="{{ rows }}" as="r" hint-placeholder-count="9">
            <div onClick="{{ r.open }}" style="position:relative;background:#FBF8F0;border:1px solid #DED5BD;border-radius:4px;padding:14px;cursor:pointer;overflow:hidden" style-hover="border-color:#13294B">
              <span style="position:absolute;left:0;top:0;bottom:0;width:4px;{{ r.barStyle }}"></span>
              <div style="display:flex;gap:11px;align-items:flex-start;margin-left:5px">
                <img src="{{ r.avatar }}" alt="" loading="lazy" style="width:48px;height:48px;border-radius:4px;object-fit:cover;object-position:center top;flex:none;background:#E7E0CF;border:1px solid #DDD3BB">
                <div style="flex:1;min-width:0">
                  <div style="display:flex;align-items:center;gap:6px"><span style="font-family:'Newsreader',serif;font-weight:600;font-size:16px;color:#13294B;line-height:1.1">{{ r.name }}</span><span style="{{ r.freshDot }}"></span></div>
                  <div style="color:#857E69;font-size:11.5px;margin-top:2px">{{ r.role }}</div>
                </div>
              </div>
              <div style="margin:11px 0 0 5px"><span style="{{ r.tierBadge }}">{{ r.statusLabel }}</span><span style="{{ r.starStyle }}">★</span></div>
              <div style="margin:9px 5px 0;font-size:12.5px;color:#4F4A3C;line-height:1.45;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">{{ r.headline }}</div>
              <div style="display:flex;align-items:center;justify-content:space-between;margin:11px 5px 0;padding-top:10px;border-top:1px solid #ECE4D2">
                <span style="display:inline-flex;align-items:center;gap:6px;font-size:11.5px;color:#6A6450"><span style="{{ r.laneStyle }}">{{ r.letter }}</span>{{ r.party }}</span>
                <span style="font-family:'Space Mono',monospace;font-weight:700;font-size:19px;{{ r.scoreColor }}">{{ r.score }}</span>
              </div>
            </div>
          </sc-for>
        </div>
        </sc-if>

        <sc-if value="{{ noResults }}" hint-placeholder-val="{{ false }}">
          <div style="text-align:center;padding:46px 0;color:#8A8470;font-size:13.5px">No candidates match these filters. <span onClick="{{ clearFilters }}" style="color:#9E3B34;cursor:pointer;text-decoration:underline;text-underline-offset:3px">Clear filters</span></div>
        </sc-if>
      </div>

      <!-- SIDEBAR -->
      <aside style="display:flex;flex-direction:column;gap:16px;position:sticky;top:88px">
        <div style="background:#FBF8F0;border:1px solid #DED5BD;border-radius:4px;overflow:hidden">
          <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 15px;border-bottom:1px solid #E4DBC6">
            <h2 style="font-family:'Newsreader',serif;font-weight:600;font-size:15px;margin:0">Latest movement</h2>
            <button onClick="{{ goWire }}" style="appearance:none;border:0;background:none;cursor:pointer;font:inherit;font-size:11px;color:#9E3B34;font-weight:600;letter-spacing:.02em">The Wire →</button>
          </div>
          <div>
            <sc-for list="{{ feed }}" as="f" hint-placeholder-count="7">
              <div onClick="{{ f.open }}" style="padding:10px 15px;border-bottom:1px solid #ECE4D2;cursor:pointer" style-hover="background:#F5EFDF">
                <div style="display:flex;align-items:center;gap:7px;font-size:10px;text-transform:uppercase;letter-spacing:.05em;color:#9A917A;font-weight:600"><span style="{{ f.dotStyle }}"></span>{{ f.date }} · {{ f.party }}</div>
                <div style="font-size:12.5px;margin-top:3px;line-height:1.4"><span style="font-weight:600;color:#13294B">{{ f.name }}</span><span style="color:#5A5443"> — {{ f.headline }}</span></div>
              </div>
            </sc-for>
          </div>
        </div>

        <div style="background:#FBF8F0;border:1px solid #DED5BD;border-radius:4px;overflow:hidden">
          <h2 style="font-family:'Newsreader',serif;font-weight:600;font-size:15px;margin:0;padding:12px 15px;border-bottom:1px solid #E4DBC6">Status tiers</h2>
          <div style="padding:6px 15px 13px">
            <sc-for list="{{ tiers }}" as="t" hint-placeholder-count="6">
              <div style="display:flex;gap:10px;align-items:baseline;margin:9px 0">
                <span style="{{ t.badge }}">{{ t.rank }}</span>
                <span><span style="font-weight:600;color:#13294B;font-size:12.5px">{{ t.label }}</span><span style="display:block;color:#7A7460;font-size:11.5px;line-height:1.35">{{ t.desc }}</span></span>
              </div>
            </sc-for>
