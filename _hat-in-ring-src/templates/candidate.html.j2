<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ c.name }} — 2028 presidential status &amp; signals · Hat-in-Ring Radar</title>
<meta name="description" content="{{ meta_desc }}">
<link rel="canonical" href="{{ canonical }}">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="alternate" type="application/rss+xml" title="Hat-in-Ring Radar — daily movement" href="https://hatinring.com/feed.xml">
<meta name="theme-color" content="#f6f5f1">
<meta name="robots" content="index,follow">
<meta property="og:type" content="profile">
<meta property="og:site_name" content="Hat-in-Ring Radar">
<meta property="og:title" content="{{ c.name }} — 2028 status &amp; signals">
<meta property="og:description" content="{{ meta_desc }}">
<meta property="og:url" content="{{ canonical }}">
<meta property="og:image" content="{{ og_image }}">
<meta property="og:image:alt" content="{{ c.name }} portrait">
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="{{ c.name }} — Hat-in-Ring Radar">
<meta name="twitter:description" content="{{ meta_desc }}">
<meta name="twitter:image" content="{{ og_image }}">
<script type="application/ld+json">{{ person_jsonld|safe }}</script>
<script type="application/ld+json">{{ breadcrumbs_jsonld|safe }}</script>
<style>
  :root{--bg:#f6f5f1;--panel:#fff;--ink:#1a1a1a;--muted:#6b6b6b;--line:#e3e1da;--dem:#2f6fd1;--rep:#d23b3b;--lib:#c79a18;--ind:#3b9c8a;--good:#1f9d55;--bad:#c0392b;
    --t5:#c0392b;--t4:#e07a1f;--t3:#d4a017;--t2:#2f6fd1;--t1:#7d8794;--t0:#aab0b6}
  *{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--ink);font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;font-size:16px;line-height:1.55}
  .wrap{max-width:760px;margin:0 auto;padding:24px 20px 70px}
  h1,h2{font-family:Georgia,"Times New Roman",serif;letter-spacing:-.01em}
  h1{font-size:32px;margin:0}
  h2{font-size:19px;margin:30px 0 8px;padding-top:14px;border-top:1px solid var(--line)}
  a{color:var(--dem);text-decoration:none}a:hover{text-decoration:underline}
  .back{display:inline-block;margin-bottom:16px;font-weight:600}
  .hd{display:flex;gap:16px;align-items:flex-start}
  .hd img{width:76px;height:76px;border-radius:12px;object-fit:cover;object-position:center top;background:#ece9e2;border:1px solid var(--line);flex:none}
  .role{color:var(--muted);font-size:14px;margin-top:3px}
  .tier{display:inline-block;font-size:12px;font-weight:700;padding:3px 10px;border-radius:999px;color:#fff}
  .score{font-family:Georgia,serif;font-size:30px;font-weight:600;line-height:1}
  .axisrow{display:flex;gap:24px;align-items:center;margin:14px 0 4px;flex-wrap:wrap}
  .axis .l{font-size:11px;text-transform:uppercase;letter-spacing:.04em;color:var(--muted)}
  .call{background:#fff;border:1px solid var(--line);border-left:3px solid var(--rep);border-radius:8px;padding:10px 13px;margin:14px 0;font-size:14px}
  table{width:100%;border-collapse:collapse;font-size:14.5px;margin:8px 0}
  td{padding:7px 4px;border-bottom:1px dashed var(--line)}
  td.v{text-align:right;font-variant-numeric:tabular-nums;font-weight:600}
  td.v.pos{color:var(--good)}td.v.neg{color:var(--bad)}
  .ev{margin:6px 0;padding:9px 0;border-bottom:1px solid var(--line)}
  .ev:last-child{border-bottom:0}
  .ev .d{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.03em}
  .ev .h{margin:3px 0}
  .kchip{display:inline-block;font-size:11px;background:#eef;color:#33438a;border:1px solid #dfe3f5;border-radius:5px;padding:1px 6px;margin-right:4px}
  .muted{color:var(--muted)}
  .tag{display:inline-block;font-size:12px;background:#f1efe9;border-radius:5px;padding:2px 8px;margin:2px 4px 2px 0;color:#555}
  footer{margin-top:36px;padding-top:14px;border-top:2px solid var(--ink);font-size:13px;color:var(--muted)}
  .corr{background:#eef5ff;border:1px solid #d4e3fb;border-radius:8px;padding:12px 14px;margin-top:8px;font-size:14px}
  .spark{border:1px solid var(--line);border-radius:8px;padding:12px 14px;margin:12px 0 4px;max-width:360px}
  .spark .sl{font-size:11px;text-transform:uppercase;letter-spacing:.04em;color:var(--muted)}
  .spark .sv{font-family:Georgia,serif;font-size:30px;font-weight:600;line-height:1.15}
  .spark .sd{font-size:13px;color:var(--muted)}
  .spark svg{display:block;width:100%;max-width:320px;height:auto;margin-top:8px}
  .vh{position:absolute;width:1px;height:1px;margin:-1px;padding:0;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0}
  @media (max-width:768px){
    .wrap{max-width:none;padding:18px 14px 56px}
    .back{min-height:44px;display:inline-flex;align-items:center}
    .hd{gap:12px}
    .hd img{width:68px;height:68px;border-radius:10px}
    h1{font-size:28px;line-height:1.08}
    .axisrow{gap:12px}
    table{display:block;overflow-x:auto;-webkit-overflow-scrolling:touch}
    td{min-width:120px}
  }
</style>
</head>
<body>
<div class="wrap">
  <a class="back" href="/">&larr; All candidates</a>
  <div class="hd">
    {% if c.img %}<img src="/{{ c.img }}" alt="{{ c.name }}">{% endif %}
    <div>
      <h1>{{ c.name }}</h1>
      <div class="role">{{ c.role }} · <span style="color:{{ party_color }};font-weight:600">{{ c.party }}</span>{% if c.pollLead %} · <span class="muted">★ {{ c.pollLead }}</span>{% endif %}{% if wiki %} · <a href="{{ wiki }}" target="_blank" rel="noopener" style="white-space:nowrap">Wikipedia ↗</a>{% endif %}</div>
      <div class="axisrow">
        <div class="axis"><div class="l">Status tier</div><span class="tier" style="background:{{ tier_color }}">{{ c.statusLabel }}</span></div>
        <div class="axis"><div class="l">Momentum (0–100)</div><span class="score" style="color:{{ tier_color }}">{{ c.score }}</span></div>
        <div class="axis"><div class="l">Confidence</div><b>{{ c.conf }}</b></div>
      </div>
    </div>
  </div>

  <div class="call"><b>Status is not support.</b> Status tier = the furthest verifiable step taken ({{ status_def }}). Momentum = weighted recent activity, not popularity. <a href="/about.html#how-to">How to read this →</a></div>
  <p class="muted" style="font-size:13.5px">Last reviewed in the <b>{{ as_of }}</b> UTC daily build · latest signal {{ last_signal_human }}{% if days_ago %} ({{ days_ago }}){% endif %}.</p>

  <h2>Latest signal</h2>
  <p>{{ c.headline }}{% if source_url %} <a href="{{ source_url }}" target="_blank" rel="noopener noreferrer" style="white-space:nowrap">source ↗</a>{% endif %}<br>
  <span class="muted">{{ last_signal_human }}{% if days_ago %} · {{ days_ago }}{% endif %} · {{ c.conf }} confidence</span></p>
  {% if c.quote %}<blockquote style="border-left:3px solid var(--line);margin:10px 0;padding:4px 0 4px 13px;font-style:italic;color:#333">“{{ c.quote }}”</blockquote>{% endif %}
  {% if c.why %}<p>{{ c.why }}</p>{% endif %}

  <h2>Why this momentum score</h2>
  <figure class="spark">
    <div class="sl">Momentum · last 30 days</div>
    <div class="sv">{{ c.score }}</div>
    {% if spark %}
    <div class="sd">{{ spark.delta }}</div>
    <svg viewBox="0 0 240 48" width="240" height="48" role="img" aria-label="{{ spark.aria }}">
      <title>{{ spark.aria }}</title>
      <line x1="{{ spark.base.x1 }}" y1="{{ spark.base.y }}" x2="{{ spark.base.x2 }}" y2="{{ spark.base.y }}" style="stroke:var(--line)" stroke-width="1"/>
      <polygon points="{{ spark.area }}" style="fill:{{ party_color }}" fill-opacity=".1"/>
      <polyline points="{{ spark.points }}" fill="none" style="stroke:{{ party_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="{{ spark.end.x }}" cy="{{ spark.end.y }}" r="4" style="fill:{{ party_color }};stroke:var(--bg)" stroke-width="2"/>
      <text x="{{ spark.label.x }}" y="{{ spark.label.y }}" font-size="11" font-weight="600" style="fill:var(--ink)">{{ spark.label.text }}</text>
    </svg>
    <figcaption class="vh">{{ spark.aria }}</figcaption>
    {% else %}
    <div class="sd">Trend line appears as daily snapshots accumulate.</div>
    {% endif %}
  </figure>
  <table>
    {% for b in breakdown %}<tr><td>{{ b.label }}</td><td class="v {{ 'pos' if b.w >= 0 else 'neg' }}">{{ '+' if b.w >= 0 else '' }}{{ b.w }}</td></tr>{% endfor %}
    <tr><td><b>Momentum (capped 0–100)</b></td><td class="v"><b>{{ c.score }}</b></td></tr>
  </table>

  <h2>Evidence &amp; status history</h2>
  {% if evidence %}
    {% for e in evidence %}<div class="ev"><div class="d">{{ e.date }}</div><div class="h">{{ e.headline }}{% if e.url %} <a href="{{ e.url }}" target="_blank" rel="noopener noreferrer">source ↗</a>{% endif %}</div>{% for k in e['keys'] %}<span class="kchip">{{ k }}</span>{% endfor %}{% if e.conf %}<span class="muted" style="font-size:12px">· {{ e.conf }}</span>{% endif %}</div>{% endfor %}
  {% elif c.history %}
    {% for h in c.history %}<div class="ev"><div class="d">{{ h.date }} · {{ tiers[h['from']] }} → {{ tiers[h['to']] }}</div><div class="h">{{ h.reason }}</div></div>{% endfor %}
  {% else %}
    <p class="muted">Seeded from curated public reporting; no automated signal changes recorded yet. New signals from FEC filings and news will appear here, dated and sourced.</p>
  {% endif %}

  {% if early_list %}<h2>Early-state activity</h2><table>{% for s in early_list %}<tr><td>{{ s.name }}</td><td class="v">{{ s.n }} signal{{ 's' if s.n != 1 else '' }}</td></tr>{% endfor %}</table>{% endif %}

  <h2>Money movement <span class="muted" style="font-weight:400;font-size:14px">— FEC, a separate axis</span></h2>
  {% if c.money %}
  <table>
    <tr><td>Receipts</td><td class="v">{{ money_fmt.receipts }}</td></tr>
    <tr><td>Disbursements</td><td class="v">{{ money_fmt.disbursements }}</td></tr>
    <tr><td>Cash on hand</td><td class="v">{{ money_fmt.cash_on_hand }}</td></tr>
    <tr><td>Debts</td><td class="v">{{ money_fmt.debts }}</td></tr>
  </table>
  <p class="muted" style="font-size:13px">{{ c.money.committee or '' }}{% if c.money.coverage_end %} · through {{ c.money.coverage_end }}{% endif %}{% if c.money.source %} · <a href="{{ c.money.source }}" target="_blank" rel="noopener">FEC ↗</a>{% endif %}</p>
  {% else %}
  <p class="muted">No FEC financial report on file — not a registered filer, or no totals yet. Money is never folded into the momentum score.</p>
  {% endif %}

  {% if c.tags %}<h2>Tags</h2>{% for t in c.tags %}<span class="tag">{{ t }}</span>{% endfor %}{% endif %}

  <h2>Something wrong?</h2>
  <div class="corr"><b>Corrections welcome.</b> If a status, source, or date here is wrong or stale, <a href="{{ corrections_url }}" target="_blank" rel="noopener">flag it in 30 seconds →</a> with what's wrong and a link. Confirmed corrections apply on the next daily build.</div>

  {% if related %}
  <nav aria-label="Related candidates">
    <h2>Compare with</h2>
    <p>{% for o in related %}<a href="/c/{{ o.id }}/">{{ o.name }}</a> <span class="muted">({{ o.statusLabel }})</span>{% if not loop.last %} · {% endif %}{% endfor %}</p>
  </nav>
  {% endif %}

  {% if vs_nav %}
  <nav aria-label="Head-to-head comparisons">
    <h2>Head-to-head</h2>
    <p>{% for v in vs_nav %}<a href="/vs/{{ v.slug }}/">vs {{ v.other_name }}</a>{% if not loop.last %} · {% endif %}{% endfor %}</p>
  </nav>
  {% endif %}

  <footer>
    Data from public reporting (AP, Reuters, Time, WaPo, ABC, C-SPAN, FEC). Rebuilt daily · as of {{ as_of }} UTC.
    <a href="/about.html">Methodology</a> · <a href="/">Live board</a> · <a href="https://github.com/DaveHomeAssist/hatinring">Open data</a>.
    Hat-in-Ring Radar is not affiliated with any campaign. Status ≠ support.
  </footer>
</div>
</body>
</html>
