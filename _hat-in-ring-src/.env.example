# Copy to .env and fill in. Only FEC_API_KEY is needed for the FEC source.
# Get a free key in ~30s: https://api.data.gov/signup/
FEC_API_KEY=DEMO_KEY

# Optional: enables the LLM adjudication upgrade in classify.py (paid).
# Leave unset to use the deterministic rules engine (the supported default).
# ANTHROPIC_API_KEY=
